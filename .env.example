# Copy this file to .env and fill only the providers you use.
# Never commit .env or real credentials.

# Direct model-provider credentials. Fill only the providers you use.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional OpenRouter/OpenAI-compatible model configuration.
OPENROUTER_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# Pi orchestrator: the model that plans stages and calls tools.
ORCHESTRATOR_MODEL_PROVIDER=deepseek
ORCHESTRATOR_MODEL_ID=deepseek-v4-pro
ORCHESTRATOR_THINKING=medium

# Research workers: one economical model shared by screening, extraction, and validation.
WORKER_MODEL_PROVIDER=deepseek
WORKER_MODEL_ID=deepseek-v4-flash

# Legacy fallback. Existing installations may keep these instead of the role-specific settings.
# RESEARCH_MODEL_PROVIDER=deepseek
# RESEARCH_MODEL_ID=deepseek-v4-pro
RESEARCH_MAX_LLM_WORKERS=5
RESEARCH_MAX_RETRIEVAL_WORKERS=10

# Literature metadata and full-text retrieval.
ELSEVIER_API_KEY=
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
NCBI_API_KEY=
NCBI_EMAIL=
UNPAYWALL_EMAIL=
CROSSREF_MAILTO=

# Local Firecrawl. Change the URL if the service is hosted elsewhere.
FIRECRAWL_API_URL=http://localhost:3002
FIRECRAWL_API_KEY=
